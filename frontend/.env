NODE_ENV=development

# Expo Public Builder Key (optional)
PUBLIC_BUILDER_KEY=

# Google Sign-In Web Client ID (from Google Cloud Console)
# Get this from: https://console.cloud.google.com/apis/credentials
# IMPORTANT: Use the WEB client ID, not Android or iOS client ID
GOOGLE_WEB_CLIENT_ID=969529169540-vkaojfsqj9n4167e0a2cbahlh5ogkn8v.apps.googleusercontent.com


# ============================================
# BACKEND DATABASE CONFIG (PRODUCTION DATABASE)
# ============================================

# MySQL Hostname (from cPanel > MySQL Databases)
# Example: localhost OR server123.yourhost.com
DB_HOST=YOUR_MYSQL_HOSTNAME_HERE

# MySQL Port (default = 3306)
DB_PORT=3306

# Production Database Name
DB_DATABASE=greenfieldsuperm_db

# Production Database User
DB_USERNAME=greenfieldsuperm_user

# Production Database Password (RESET this)
