# Exclude unnecessary files from EAS Build uploads

# Node modules cache
node_modules/**/.cache
node_modules/**/test
node_modules/**/tests
node_modules/**/__tests__
node_modules/**/docs
node_modules/**/examples
node_modules/**/*.md

# Test files
**/__tests__
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
__tests__/

# Documentation
*.md
docs/
documentation/

# Git
.git/
.github/
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# Build artifacts
build/
dist/
.expo/
.expo-shared/
web-build/

# Android/iOS build folders (will be regenerated)
android/build/
android/app/build/
android/.gradle/
ios/build/
ios/Pods/
ios/.xcode.env.local

# Large media files (if any)
*.mp4
*.mov
*.avi
*.webm

# Source maps
*.map

# Coverage
coverage/
.nyc_output/

# Temporary files
tmp/
temp/
.tmp/

# Backend (don't need to upload)
../backend/
